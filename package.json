{
  "name": "localpush",
  "version": "0.7.0",
  "description": "Push local file changes to webhooks with guaranteed delivery",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "node scripts/run-tauri.mjs",
    "bump:version": "node scripts/bump-version.mjs",
    "cargo:check": "node scripts/run-cargo.mjs check --manifest-path src-tauri/Cargo.toml --all-targets",
    "cargo:test": "node scripts/run-cargo.mjs test --manifest-path src-tauri/Cargo.toml",
    "cargo:clippy": "node scripts/run-cargo.mjs clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "cargo:build:release": "node scripts/run-cargo.mjs build --manifest-path src-tauri/Cargo.toml --release",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx biome check src/ && eslint src/",
    "lint:fix": "npx biome check --write src/ && eslint --fix src/",
    "lint:ci": "npx biome ci src/ && eslint src/ --max-warnings=331",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint:ci && npm run typecheck && npm test && npm run cargo:test"
  },
  "dependencies": {
    "@choochmeque/tauri-plugin-google-auth-api": "^0.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "lucide-react": "^0.563.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@rightaim/coding-craft": "^1.0.0",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "jsdom": "^23.0.0",
    "lefthook": "^2.1.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
